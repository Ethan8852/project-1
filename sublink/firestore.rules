rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{uid} {
      allow read, write: if request.auth.uid == uid;
    }

    match /products/{productId} {
      allow read: if request.auth != null;
      allow create: if request.auth.uid == request.resource.data.ownerId;
      allow update, delete: if request.auth.uid == resource.data.ownerId;
    }

    match /subscriptions/{subscriptionId} {
      allow read: if request.auth.uid == resource.data.ownerId
                  || request.auth.uid == resource.data.customerId;
      allow create: if request.auth.uid == request.resource.data.customerId
                    && request.resource.data.status in ['active', 'paused']
                    && request.resource.data.sellerId == request.resource.data.ownerId;
      // 고객: 상태 변경 + 수량/가격 수정
      // 판매자: 상태 변경 + 구독 정보 수정
      allow update: if (request.auth.uid == resource.data.customerId
                        && request.resource.data.status in ['active', 'paused', 'cancelled'])
                    || (request.auth.uid == resource.data.ownerId
                        && request.resource.data.status in ['active', 'paused', 'cancelled']);
      allow delete: if request.auth.uid == resource.data.ownerId;
    }

    match /wallets/{uid} {
      allow read, write: if request.auth != null;
    }

    match /charges/{chargeId} {
      allow read: if request.auth != null;
      allow create: if request.auth.uid == request.resource.data.userId;
      allow update: if request.auth != null;
    }

    match /deductions/{deductionId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
    }

    match /withdrawals/{withdrawalId} {
      allow read: if request.auth != null;
      allow create: if request.auth.uid == request.resource.data.userId;
    }

    match /deliveries/{deliveryId} {
      allow read, write: if request.auth != null;
    }
  }
}
